<div class="container mt-3">
    <div class="jumbotron">
<h1 style="color:blue;">Register new product</h1>
<br>

<form action="/products" method="post">

    <div class="form-group">
        <label for="title"><b>Title</b></label>
        <input class="form-control"  id="title" type="text" name="title" required>
    </div>

    <div class="form-group">
        <label for="price"><b>Price</b></label>
        <input  class="form-control" id="price" type="text" name="price" required>
    </div>

    <div class="form-group">
        <label for="thumbnail"><b>Thumbnail</b></label>
        <input  class="form-control" id="thumbnail" type="text" name="thumbnail" required>
    </div>

    <button class="btn btn-success mt-3 mb-5">Register</button>
    
</form>
<button class="btn btn-secondary" ><a href="/products" style="color:white;">Show Products</a></button>
</div>
</div>