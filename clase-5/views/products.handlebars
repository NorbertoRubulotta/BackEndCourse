
<h2 style="color:crimson;">Historial</h2>

{{#if products}}
<div class="table-responsive">
<table class="table table-dark">
    <tr style="color: rgb(88, 188, 228);">
        <th>TITLE</th>
        <th>PRICE</th>
        <th>THUMBNAIL</th>
    </tr>
    {{#each products}}
    <tr>
        <td>
            {{this.title}}
        </td>
        <td>
            {{this.price}}
        </td>
        <td>
            <img src={{this.thumbnail}} style="width: 3rem;"></img>
        </td>
    </tr>
    {{/each}}
</table>
</div>
{{else}}
<h3 class="alert alert-danger">The list of products is empty</h3>
{{/if}}

<button class="btn btn-primary" ><a href="/" style="color:white;">Back to form</a></button>